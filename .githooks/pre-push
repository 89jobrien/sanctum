#!/usr/bin/env bash
# Stamp plugin.json with current commit hash, then reinstall if plugin sources changed.

MANIFEST=".claude-plugin/plugin.json"
[ -f "$MANIFEST" ] || exit 0

REMOTE_BEFORE=$(git rev-parse "@{u}" 2>/dev/null || echo "")
HASH=$(git rev-parse --short HEAD)
current=$(grep '"version"' "$MANIFEST" | head -1 | sed 's/.*"version": *"\([^"]*\)".*/\1/')

# Stamp version
if [ "$current" != "$HASH" ]; then
  sed -i '' "s/\"version\": \"$current\"/\"version\": \"$HASH\"/" "$MANIFEST"
  git add "$MANIFEST"
  git commit -m "chore: set plugin version to $HASH"
  echo "[sanctum] version set to $HASH"
fi

# Reinstall if plugin sources changed since remote tip
if [ -n "$REMOTE_BEFORE" ]; then
  PLUGIN_FILES=$(git diff --name-only "$REMOTE_BEFORE" HEAD 2>/dev/null \
    | grep -E '^(\.claude-plugin/|skills/|agents/|hooks/)' || true)
else
  PLUGIN_FILES=$(git diff --name-only HEAD~1 HEAD 2>/dev/null \
    | grep -E '^(\.claude-plugin/|skills/|agents/|hooks/)' || true)
fi

if [ -n "$PLUGIN_FILES" ] && command -v claude >/dev/null 2>&1; then
  echo "[sanctum] plugin sources changed — reinstalling..."
  claude plugin marketplace update bazaar 2>/dev/null || true
  claude plugin uninstall sanctum --force 2>/dev/null || true
  claude plugin install sanctum@bazaar
  echo "[sanctum] plugin reinstalled (restart Claude Code to apply)"
fi
